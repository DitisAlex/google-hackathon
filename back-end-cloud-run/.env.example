APP_NAME=repo-doc-generator
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
REQUEST_RATE_LIMIT=10/minute
MAX_JOB_TIMEOUT_SECONDS=120
MAX_REQUEST_BODY_BYTES=10240
MAX_FILE_SIZE_BYTES=102400
GEMINI_PRIMARY_MODEL=gemini-3
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
ENABLE_CLOUD_TRACE=false
CORS_ALLOW_ORIGINS=["*"]
